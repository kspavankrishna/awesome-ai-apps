# Required
SGAI_API_KEY=your_scrapegraph_api_key_here

# Optional but recommended. Pick one provider path below.

# Option 1: OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Option 2: OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Option 3: Nebius
NEBIUS_API_KEY=your_nebius_api_key_here
NEBIUS_MODEL=deepseek-ai/DeepSeek-V3-0324

# Optional explicit provider override: openrouter | openai | nebius | auto
MODEL_PROVIDER=auto
